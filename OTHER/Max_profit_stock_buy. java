class Solution {
    public int maxProfit(int[] prices) {
        int min = prices[0];
        int max = 0;
        for(int i = 1; i < prices.length; i++){
            if(prices[i] < min){
                min = prices[i];
            }

            int current = prices[i];
            max = Math.max(max,current - min);
        }
        return max;
    }
}

